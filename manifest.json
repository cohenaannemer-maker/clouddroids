<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="theme-color" content="#060b18"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="CloudDroid"/>
<title>CloudDroid</title>
<link rel="manifest" href="/manifest.json"/>
<link rel="apple-touch-icon" href="/icons/icon-192.png"/>
<link rel="icon" href="/icons/icon-192.png"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:#060b18;color:#e2e8f0;font-family:'Outfit',sans-serif;-webkit-tap-highlight-color:transparent;overflow:hidden}
#app{height:100%;overflow-y:auto;-webkit-overflow-scrolling:touch}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:rgba(124,58,237,.3);border-radius:3px}
button{cursor:pointer;font-family:inherit;border:none;outline:none}
button:active{opacity:.8}
input{font-family:inherit;outline:none}
input[type=range]{accent-color:#7c3aed}
@keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes ping{0%{transform:scale(1);opacity:.6}80%,100%{transform:scale(2.4);opacity:0}}
@keyframes glow{0%,100%{box-shadow:0 0 30px #7c3aed40}50%{box-shadow:0 0 70px #7c3aed70}}
.anim{animation:fadeIn .35s ease both}
.spin{animation:spin 1s linear infinite}

/* Install banner */
#ib{position:fixed;top:0;left:0;right:0;z-index:999;background:linear-gradient(135deg,#7c3aed,#6d28d9);padding:11px 16px;display:flex;align-items:center;gap:10px;transform:translateY(-100%);transition:transform .4s;box-shadow:0 4px 20px #7c3aed80}
#ib.show{transform:translateY(0)}
#ios-hint{position:fixed;bottom:90px;left:14px;right:14px;background:#0f172a;border:1px solid rgba(124,58,237,.3);border-radius:14px;padding:16px;display:none;z-index:998;animation:fadeIn .3s ease;backdrop-filter:blur(16px)}
#ios-hint.show{display:block}
#toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(16px);background:rgba(15,23,42,.96);border:1px solid rgba(124,58,237,.3);border-radius:10px;padding:9px 18px;color:#e2e8f0;font-size:13px;font-weight:600;z-index:500;opacity:0;transition:all .3s;white-space:nowrap;pointer-events:none;backdrop-filter:blur(12px)}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* Layout */
.screen{min-height:100vh;background:#060b18;display:flex;flex-direction:column}
.center{min-height:100vh;background:#060b18;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px 22px;text-align:center;position:relative;overflow:hidden}

/* Top bar */
.bar{position:sticky;top:0;z-index:10;background:rgba(6,11,24,.96);border-bottom:1px solid rgba(255,255,255,.06);padding:13px 18px;display:flex;align-items:center;gap:11px;backdrop-filter:blur(14px)}
.logo{width:35px;height:35px;border-radius:10px;background:linear-gradient(135deg,#7c3aed,#6d28d9);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;animation:glow 3s ease-in-out infinite}
.dot{position:relative;display:inline-block;width:8px;height:8px;flex-shrink:0}
.dot::before{content:'';position:absolute;inset:0;border-radius:50%;background:#34d399;animation:ping 1.4s ease-out infinite;opacity:.5}
.dot::after{content:'';position:absolute;inset:1px;border-radius:50%;background:#34d399}

/* Stats */
.stats{display:flex;gap:9px;padding:12px 18px;overflow-x:auto}
.sc{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:11px;padding:9px 14px;flex-shrink:0;min-width:80px;text-align:center}

/* Tabs */
.tabs{display:flex;gap:4px;padding:0 18px 12px;border-bottom:1px solid rgba(255,255,255,.05)}
.tab{border-radius:9px;padding:6px 13px;font-weight:600;font-size:13px;transition:all .2s}
.tab.on{background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff}
.tab.off{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);color:#475569}

/* Content */
.body{padding:18px;padding-bottom:82px}

/* Cards */
.card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:16px;margin-bottom:14px}
.card-v{background:rgba(124,58,237,.06);border:1px solid rgba(124,58,237,.18);border-radius:14px;padding:14px;margin-bottom:14px}
.card-g{background:rgba(52,211,153,.05);border:1px solid rgba(52,211,153,.2);border-radius:13px;padding:12px 14px;margin-bottom:14px;display:flex;align-items:center;gap:10px}
.card-y{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:12px;padding:11px 14px;margin-bottom:14px;display:flex;align-items:center;gap:8px}

/* Buttons */
.btn{background:linear-gradient(135deg,#7c3aed,#6d28d9);border:none;border-radius:13px;padding:14px;color:#fff;font-size:15px;font-weight:700;box-shadow:0 6px 24px rgba(124,58,237,.35);width:100%;transition:transform .15s}
.btn:hover{transform:scale(1.01)}
.btn-o{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:11px;padding:11px;color:#94a3b8;font-size:13px;font-weight:600;width:100%}
.btn-v{background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.25);border-radius:10px;padding:9px 14px;color:#a78bfa;font-size:13px;font-weight:600}
.btn-r{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);border-radius:10px;padding:10px;color:#f87171;font-size:13px;font-weight:600;width:100%}
.btn-g{background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);border-radius:10px;padding:10px;color:#34d399;font-size:13px;font-weight:600;width:100%}

/* App grid */
.agrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px}
.aitem{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:13px;padding:13px 8px;text-align:center;transition:border-color .25s}
.aitem.on{border-color:rgba(52,211,153,.25)}

/* Android frame */
.aframe{background:#0a0a14;border-radius:16px;border:2px solid rgba(255,255,255,.1);overflow:hidden;margin-bottom:14px}
.abar{background:#111;padding:4px 12px;display:flex;justify-content:space-between;font-size:10px;color:#666}
.ahome{background:#1a1a2e;display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:14px;min-height:180px;align-content:start}
.aapp{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer}
.anav{background:#111;padding:6px;display:flex;justify-content:center;gap:24px}
.anav button{background:none;color:#777;font-size:17px;padding:2px 8px}
.divr{border-bottom:1px solid rgba(255,255,255,.04);padding:11px 0;display:flex;align-items:center;gap:11px}

/* Bottom nav */
.nav{position:fixed;bottom:0;left:0;right:0;background:rgba(6,11,24,.97);border-top:1px solid rgba(255,255,255,.06);display:flex;backdrop-filter:blur(16px);z-index:20}
.nb{flex:1;background:none;padding:9px 0;display:flex;flex-direction:column;align-items:center;gap:3px}

/* Spinner */
.sp{display:inline-block;width:14px;height:14px;border:2px solid rgba(124,58,237,.3);border-top-color:#7c3aed;border-radius:50%}
.sp-sm{width:11px;height:11px;border-width:1.5px}
</style>
</head>
<body>

<div id="ib">
  <div style="flex:1"><div style="color:#fff;font-size:13px;font-weight:700">Install CloudDroid</div><div style="color:rgba(255,255,255,.6);font-size:11px">Add to home screen</div></div>
  <button id="ib-btn" style="background:#fff;border:none;border-radius:8px;padding:6px 14px;color:#7c3aed;font-weight:700;font-size:12px">Install</button>
  <button id="ib-x" style="background:none;border:none;color:rgba(255,255,255,.5);font-size:20px">✕</button>
</div>

<div id="ios-hint">
  <button onclick="this.parentElement.classList.remove('show')" style="position:absolute;top:10px;right:12px;background:none;border:none;color:#475569;font-size:18px">✕</button>
  <div style="color:#fff;font-weight:700;font-size:14px;margin-bottom:8px">📲 Install on iPhone</div>
  <div style="color:#64748b;font-size:13px;line-height:1.9">
    1. Tap <strong style="color:#7c3aed">Share ⬆️</strong><br>
    2. Tap <strong style="color:#7c3aed">Add to Home Screen</strong><br>
    3. Tap <strong style="color:#7c3aed">Add</strong>
  </div>
</div>

<div id="toast"></div>
<div id="app"></div>

<script>
// ── State ──────────────────────────────────────────────────────
const S = {
  screen:'splash', tab:'android',
  user:null, token:null,
  apps:[], storage:null, status:null, android:null,
  ld:{}, lastSync:'Never',
};

// ── Utils ──────────────────────────────────────────────────────
const $  = id => document.getElementById(id);
const sl = ms => new Promise(r=>setTimeout(r,ms));
const LS = {
  g:k=>{try{return JSON.parse(localStorage.getItem('cd_'+k))}catch{return null}},
  s:(k,v)=>{try{localStorage.setItem('cd_'+k,JSON.stringify(v))}catch{}},
  d:k=>{try{localStorage.removeItem('cd_'+k)}catch{}},
};

let _tt;
function toast(m,d=2800){
  const el=$('toast'); if(!el)return;
  el.textContent=m; el.classList.add('show');
  clearTimeout(_tt); _tt=setTimeout(()=>el.classList.remove('show'),d);
}

// ── API ────────────────────────────────────────────────────────
async function api(path,opts={}){
  try{
    const h={'Content-Type':'application/json'};
    if(S.token) h['Authorization']='Bearer '+S.token;
    const r=await fetch('/api'+path,{
      headers:h, method:opts.body?'POST':'GET', ...opts,
      body:opts.body?JSON.stringify(opts.body):undefined,
    });
    if(!r.ok) throw new Error(r.status);
    return await r.json();
  }catch(e){console.warn('api',path,e.message);return null;}
}

// ── Render ─────────────────────────────────────────────────────
function render(){
  const el=$('app'); if(!el)return;
  if(S.screen==='splash')    el.innerHTML=splashH();
  else if(S.screen==='signin') el.innerHTML=signinH();
  else                         el.innerHTML=dashH();
  bindAll();
}

// ── SPLASH ─────────────────────────────────────────────────────
function splashH(){return`
<div class="center">
  <div style="position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(#7c3aed0d,transparent 70%);top:-60px;left:-80px;pointer-events:none"></div>
  <div style="position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(#6d28d908,transparent 70%);bottom:-40px;right:-40px;pointer-events:none"></div>
  <div style="position:relative;margin-bottom:24px;animation:fadeIn .5s ease both">
    <div class="logo" style="width:82px;height:82px;border-radius:22px;font-size:40px;margin:0 auto">🤖</div>
    <div style="position:absolute;inset:-5px;border-radius:27px;border:1px solid rgba(124,58,237,.2)" class="spin"></div>
  </div>
  <h1 style="font-family:'Syne',sans-serif;font-weight:800;font-size:40px;color:#fff;margin:0 0 10px;letter-spacing:-1.2px;animation:fadeIn .5s .1s ease both;opacity:0">
    Cloud<span style="background:linear-gradient(90deg,#7c3aed,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Droid</span>
  </h1>
  <p style="color:#475569;font-size:14px;line-height:1.8;margin:0 0 28px;animation:fadeIn .5s .2s ease both;opacity:0">
    Run Android apps in the cloud 24/7.<br>Phone off? It keeps running.
  </p>
  <div style="display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-bottom:36px;animation:fadeIn .5s .3s ease both;opacity:0">
    ${['☁️ Vercel','📱 Android 13','🔋 Always On','📦 TeraBox 1TB'].map(f=>`<span style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:4px 12px;font-size:12px;color:#64748b">${f}</span>`).join('')}
  </div>
  <button id="b-start" class="btn" style="max-width:320px;animation:fadeIn .5s .4s ease both;opacity:0">Get Started — Free</button>
  <p style="color:#1e3a5f;font-size:11px;margin-top:12px;animation:fadeIn .5s .5s ease both;opacity:0">No credit card · Vercel free tier</p>
</div>`;}

// ── SIGN IN ────────────────────────────────────────────────────
function signinH(){
  const ld=S.ld.signin;
  return`
<div class="center">
  <div style="width:100%;max-width:360px;animation:fadeIn .4s ease">
    <div style="font-size:44px;margin-bottom:14px">👋</div>
    <h2 style="font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:#fff;margin:0 0 8px">Welcome</h2>
    <p style="color:#475569;font-size:14px;line-height:1.7;margin:0 0 24px">Sign in to access your free cloud Android</p>
    <div class="card-v" style="margin-bottom:22px">
      <p style="color:#a78bfa;font-size:12px;font-weight:700;margin-bottom:10px;text-transform:uppercase;letter-spacing:.7px">Included free:</p>
      ${[['📱','Android 13 cloud container'],['☁️','Vercel serverless backend'],['📦','TeraBox 1TB storage'],['🔋','Always-on — phone can be off']].map(([i,t])=>`
      <div style="display:flex;gap:8px;margin-bottom:7px;align-items:center"><span>${i}</span><span style="color:#94a3b8;font-size:13px">${t}</span></div>`).join('')}
    </div>
    <button id="b-google" style="width:100%;background:${ld?'#0f172a':'#fff'};border:${ld?'1px solid rgba(255,255,255,.08)':'none'};border-radius:13px;padding:14px;display:flex;align-items:center;justify-content:center;gap:11px;box-shadow:${ld?'none':'0 4px 24px rgba(0,0,0,.4)'}" ${ld?'disabled':''}>
      ${ld
        ?`<div class="sp spin"></div><span style="color:#475569;font-weight:600;font-size:14px">Signing in…</span>`
        :`<svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
           <span style="color:#111827;font-weight:700;font-size:14px">Continue with Google</span>`}
    </button>
    <p style="text-align:center;color:#1e293b;font-size:11px;margin-top:14px;line-height:1.6">By continuing you agree to CloudDroid's terms</p>
  </div>
</div>`;}

// ── DASHBOARD ──────────────────────────────────────────────────
function dashH(){
  const u=S.user||{}, st=S.status||{}, tab=S.tab;
  const instCount=S.apps.filter(a=>a.installed).length;
  return`
<div class="screen">
  <div class="bar">
    <div class="logo">🤖</div>
    <div style="flex:1">
      <div style="color:#fff;font-weight:700;font-size:15px">CloudDroid</div>
      <div style="display:flex;align-items:center;gap:5px;margin-top:1px">
        <span class="dot"></span><span style="color:#34d399;font-size:11px">Online · Vercel</span>
      </div>
    </div>
    <div style="width:33px;height:33px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#6d28d9);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:12px">${u.avatar||'U'}</div>
  </div>

  <div class="stats">
    ${[
      {l:'CPU',   v:st.cpu?st.cpu+'%':'—',c:'#7c3aed'},
      {l:'RAM',   v:st.ram?st.ram+'%':'—',c:'#a78bfa'},
      {l:'Uptime',v:st.uptime||'—',       c:'#34d399'},
      {l:'Apps',  v:instCount+' active',  c:'#f59e0b'},
    ].map(x=>`<div class="sc"><div style="color:${x.c};font-weight:700;font-size:14px">${x.v}</div><div style="color:#475569;font-size:11px;margin-top:1px">${x.l}</div></div>`).join('')}
  </div>

  <div class="tabs">
    ${[['android','📱 Android'],['apps','🗂 Apps'],['storage','📦 Storage'],['settings','⚙️']].map(([t,l])=>`
    <button class="tab ${tab===t?'on':'off'}" data-tab="${t}">${l}</button>`).join('')}
  </div>

  <div class="body anim" id="tbody">
    ${tab==='android' ?androidTab():tab==='apps'?appsTab():tab==='storage'?storageTab():settingsTab()}
  </div>
</div>

<div class="nav">
  ${[['android','📱','Android'],['apps','🗂','Apps'],['storage','📦','Storage'],['settings','⚙️','Settings']].map(([t,i,l])=>`
  <button class="nb" data-tab="${t}">
    <span style="font-size:20px">${i}</span>
    <span style="font-size:10px;color:${tab===t?'#7c3aed':'#334155'};font-weight:${tab===t?700:400}">${l}</span>
  </button>`).join('')}
</div>`;}

// ── ANDROID TAB ────────────────────────────────────────────────
function androidTab(){
  const a=S.android||{}, running=a.running!==false;
  const instApps=S.apps.filter(x=>x.installed).slice(0,8);
  return`
<div style="color:#fff;font-weight:700;font-size:17px;margin-bottom:4px">Android Control</div>
<div style="color:#475569;font-size:13px;margin-bottom:16px">Waydroid container · Android 13</div>

<div class="${running?'card-g':'card-y'}">
  ${running
    ?`<span class="dot" style="--c:#34d399"></span><span style="color:#34d399;font-weight:600;font-size:13px">Android is running</span><span style="margin-left:auto;color:#34d399;font-size:12px">${a.version||'Android 13'}</span>`
    :`<span style="font-size:16px">⚠️</span><span style="color:#f59e0b;font-weight:600;font-size:13px">Android stopped</span>`}
</div>

<div class="aframe">
  <div class="abar"><span>9:41</span><span>📶 🔋 100%</span></div>
  <div class="ahome">
    ${running
      ? instApps.length
        ? instApps.map(ap=>`<div class="aapp" data-launch="${ap.id}"><div style="width:40px;height:40px;border-radius:12px;background:${ap.color}25;border:1px solid ${ap.color}50;display:flex;align-items:center;justify-content:center;font-size:22px">${ap.icon}</div><span style="color:#ddd;font-size:8px;max-width:44px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${ap.name}</span></div>`).join('')
        : `<div style="grid-column:1/-1;text-align:center;color:#334155;font-size:12px;padding:20px">Install apps in the Apps tab</div>`
      : `<div style="grid-column:1/-1;text-align:center;color:#334155;font-size:13px;padding:20px;display:flex;flex-direction:column;align-items:center;gap:8px"><span style="font-size:32px">📵</span>Android stopped</div>`}
  </div>
  <div class="anav">
    <button id="b-back">◀</button>
    <button id="b-home">⬤</button>
    <button>▣</button>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
  <button id="b-toggle" class="${running?'btn-r':'btn-g'}" style="padding:12px;font-size:13px">
    ${S.ld.toggle?`<span class="sp spin sp-sm"></span> ${running?'Stopping…':'Starting…'}`:running?'⏹ Stop Android':'▶ Start Android'}
  </button>
  <button id="b-restart" class="btn-v" style="padding:12px;font-size:13px;width:100%">🔄 Restart</button>
</div>

<div class="card">
  <div style="margin-bottom:14px">
    <div style="display:flex;justify-content:space-between;margin-bottom:7px">
      <span style="color:#94a3b8;font-size:13px">☀️ Brightness</span>
      <span style="color:#7c3aed;font-size:13px;font-weight:700" id="bv">${a.brightness||80}%</span>
    </div>
    <input type="range" id="sl-b" min="0" max="100" value="${a.brightness||80}" style="width:100%">
  </div>
  <div>
    <div style="display:flex;justify-content:space-between;margin-bottom:7px">
      <span style="color:#94a3b8;font-size:13px">🔊 Volume</span>
      <span style="color:#7c3aed;font-size:13px;font-weight:700" id="vv">${a.volume||60}%</span>
    </div>
    <input type="range" id="sl-v" min="0" max="100" value="${a.volume||60}" style="width:100%">
  </div>
</div>

<button id="b-shot" class="btn-o" style="padding:12px">📸 Take Screenshot</button>`;}

// ── APPS TAB ───────────────────────────────────────────────────
function appsTab(){
  if(!S.apps.length) return`<div style="text-align:center;padding:50px 0;color:#334155"><div style="font-size:36px;margin-bottom:12px">⏳</div>Loading…</div>`;
  const cats=[...new Set(S.apps.map(a=>a.cat))];
  return`
<div style="color:#fff;font-weight:700;font-size:17px;margin-bottom:4px">Cloud Android Apps</div>
<div style="color:#475569;font-size:13px;margin-bottom:18px">Tap Install to add apps to your cloud Android</div>
${cats.map(cat=>`
<div style="color:#7c3aed;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px">${cat}</div>
<div class="agrid">
${S.apps.filter(a=>a.cat===cat).map(app=>{
  const ing=S.ld['a_'+app.id], inst=app.installed;
  return`<div class="aitem ${inst?'on':''}">
  <div style="font-size:28px;margin-bottom:6px">${app.icon}</div>
  <div style="color:#fff;font-size:12px;font-weight:600;margin-bottom:2px">${app.name}</div>
  <div style="color:#1e293b;font-size:9px;margin-bottom:9px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${app.pkg}</div>
  <button data-aid="${app.id}" data-act="${inst?'uninstall':'install'}"
    style="width:100%;background:${inst?'rgba(52,211,153,.1)':ing?'rgba(124,58,237,.1)':`${app.color}18`};border:1px solid ${inst?'rgba(52,211,153,.3)':ing?'rgba(124,58,237,.3)':`${app.color}40`};border-radius:8px;padding:7px 3px;color:${inst?'#34d399':ing?'#a78bfa':app.color};font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:4px"
    ${ing?'disabled':''}>
    ${ing?`<span class="sp spin sp-sm"></span>`:inst?'✓ Installed':'＋ Install'}
  </button>
</div>`;}).join('')}
</div>`).join('')}`;
}

// ── STORAGE TAB ────────────────────────────────────────────────
function storageTab(){
  const sd=S.storage, sy=S.ld.sync;
  return`
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
  <div style="color:#fff;font-weight:700;font-size:17px">TeraBox Storage</div>
  <button id="b-sync" class="btn-v" style="display:flex;align-items:center;gap:5px;font-size:12px;padding:7px 12px" ${sy?'disabled':''}>
    ${sy?`<span class="sp spin sp-sm"></span> Syncing…`:'🔄 Sync'}
  </button>
</div>
<div style="color:#475569;font-size:13px;margin-bottom:18px">1TB free · Last sync: ${S.lastSync}</div>

<div class="card">
  <div style="display:flex;justify-content:space-between;margin-bottom:10px">
    <span style="color:#fff;font-weight:600">Storage Used</span>
    <span style="color:#475569;font-size:13px">${sd?`${sd.used} GB / ${sd.total} GB`:'Loading…'}</span>
  </div>
  <div style="background:#0d1117;border-radius:99px;height:9px;overflow:hidden">
    <div style="height:100%;width:${sd?sd.percent+'%':'0'};background:linear-gradient(90deg,#7c3aed,#a78bfa);border-radius:99px;transition:width .6s ease"></div>
  </div>
  <div style="display:flex;justify-content:space-between;margin-top:8px">
    <span style="color:#34d399;font-size:12px">✓ ${sd?sd.available+' GB':'—'} available</span>
  </div>
</div>

<div class="card-v" style="display:flex;align-items:center;gap:12px">
  <span style="font-size:24px">📦</span>
  <div style="flex:1"><div style="color:#a78bfa;font-weight:600;font-size:13px">TeraBox Connected</div><div style="color:#475569;font-size:12px">Automatic backup · 1TB free · No credit card</div></div>
  <span style="color:#34d399;font-size:12px;font-weight:600">Active</span>
</div>

${(sd?.folders||[]).map(f=>`
<div class="divr"><span style="font-size:20px">${f.icon}</span><span style="flex:1;color:#e2e8f0;font-size:14px">${f.name}</span><div style="text-align:right"><div style="color:#475569;font-size:12px">${f.files} files</div><div style="color:#334155;font-size:11px">${f.size}</div></div></div>`).join('')}
${!sd?`<div style="text-align:center;padding:30px;color:#334155">Loading…</div>`:''}`;
}

// ── SETTINGS TAB ───────────────────────────────────────────────
function settingsTab(){
  const u=S.user||{}, st=S.status||{};
  return`
<div style="color:#fff;font-weight:700;font-size:17px;margin-bottom:18px">Settings</div>
<div class="card">
  <div style="color:#334155;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px">Account</div>
  <div style="display:flex;align-items:center;gap:11px">
    <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#6d28d9);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:15px">${u.avatar||'U'}</div>
    <div><div style="color:#fff;font-weight:600;font-size:15px">${u.name||'User'}</div><div style="color:#475569;font-size:13px">${u.email||''}</div></div>
    <span style="margin-left:auto;background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.3);border-radius:6px;padding:2px 8px;color:#a78bfa;font-size:11px;font-weight:600">FREE</span>
  </div>
</div>
<div class="card">
  <div style="color:#334155;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px">Cloud Platform</div>
  ${[['☁️','Platform','Vercel Serverless'],['🌍','Region',st.region||'iad1'],['⏱️','Uptime',st.uptime||'—'],['🤖','Android',st.android||'Waydroid · Android 13'],['💚','Cost','$0.00 / month']].map(([i,l,v])=>`
  <div class="divr"><span style="font-size:17px;width:24px">${i}</span><span style="flex:1;color:#475569;font-size:13px">${l}</span><span style="color:#e2e8f0;font-size:13px;font-weight:600">${v}</span></div>`).join('')}
</div>
<div class="card-v" style="margin-bottom:14px">
  <div style="color:#334155;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px">Storage</div>
  <div style="display:flex;align-items:center;gap:10px"><span style="font-size:22px">📦</span><div><div style="color:#a78bfa;font-weight:600;font-size:14px">TeraBox</div><div style="color:#475569;font-size:12px">1TB free · Connected</div></div><span style="margin-left:auto;color:#34d399;font-size:12px;font-weight:600">Active</span></div>
</div>
<button id="b-out" class="btn-r">Sign Out</button>`;
}

// ── BIND ───────────────────────────────────────────────────────
function bindAll(){
  // Splash
  $('b-start')?.addEventListener('click',()=>{S.screen='signin';render();});

  // Sign in
  $('b-google')?.addEventListener('click',async()=>{
    if(S.ld.signin)return;
    S.ld.signin=true; render();
    await sl(1400);
    const r=await api('/auth',{body:{email:'user@gmail.com',name:'CloudDroid User'}});
    S.ld.signin=false;
    if(r?.ok){
      S.user=r.user; S.token=r.token;
      LS.s('user',r.user); LS.s('token',r.token);
      S.screen='dashboard'; render(); loadAll();
    } else { toast('Sign-in failed'); render(); }
  });

  // Tabs
  document.querySelectorAll('[data-tab]').forEach(b=>
    b.addEventListener('click',()=>{
      S.tab=b.dataset.tab; render();
      if(S.tab==='storage'&&!S.storage) loadStorage();
    })
  );

  // Android controls
  $('b-toggle')?.addEventListener('click',async()=>{
    if(S.ld.toggle)return;
    S.ld.toggle=true; render();
    const act=S.android?.running?'stop':'start';
    const r=await api('/android',{body:{action:act}});
    S.ld.toggle=false;
    if(r?.ok){S.android=r.android; toast(act==='start'?'▶ Android started':'⏹ Android stopped');}
    render();
  });
  $('b-restart')?.addEventListener('click',async()=>{
    const r=await api('/android',{body:{action:'restart'}});
    if(r?.ok){S.android=r.android;toast('🔄 Restarted');render();}
  });
  $('b-home')?.addEventListener('click',()=>toast('⬤ Home'));
  $('b-back')?.addEventListener('click',()=>toast('◀ Back'));
  $('b-shot')?.addEventListener('click',()=>toast('📸 Screenshot saved to TeraBox!'));

  // Sliders
  $('sl-b')?.addEventListener('input',e=>{
    const v=$('bv'); if(v) v.textContent=e.target.value+'%';
  });
  $('sl-b')?.addEventListener('change',async e=>{
    const r=await api('/android',{body:{action:'brightness',value:e.target.value}});
    if(r?.ok&&S.android) S.android.brightness=parseInt(e.target.value);
  });
  $('sl-v')?.addEventListener('input',e=>{
    const v=$('vv'); if(v) v.textContent=e.target.value+'%';
  });
  $('sl-v')?.addEventListener('change',async e=>{
    const r=await api('/android',{body:{action:'volume',value:e.target.value}});
    if(r?.ok&&S.android) S.android.volume=parseInt(e.target.value);
  });

  // App launch
  document.querySelectorAll('[data-launch]').forEach(el=>
    el.addEventListener('click',()=>{
      const app=S.apps.find(a=>a.id===el.dataset.launch);
      if(app) toast(`Opening ${app.name}…`);
    })
  );

  // App install
  document.querySelectorAll('[data-aid]').forEach(b=>
    b.addEventListener('click',async()=>{
      const id=b.dataset.aid, act=b.dataset.act;
      S.ld['a_'+id]=true; render();
      const r=await api('/apps',{body:{action:act,id}});
      S.ld['a_'+id]=false;
      if(r?.ok){
        const i=S.apps.findIndex(a=>a.id===id);
        if(i!==-1) S.apps[i].installed=r.app.installed;
        toast(r.message);
      }
      render();
    })
  );

  // Storage sync
  $('b-sync')?.addEventListener('click',async()=>{
    if(S.ld.sync)return;
    S.ld.sync=true; render();
    const r=await api('/storage',{body:{action:'sync'}});
    S.ld.sync=false;
    if(r?.ok){S.lastSync='Just now';toast(`✓ ${r.files_synced} files synced to TeraBox`);await loadStorage();}
    render();
  });

  // Sign out
  $('b-out')?.addEventListener('click',()=>{
    S.user=null;S.token=null;
    LS.d('user');LS.d('token');
    S.screen='splash';render();toast('Signed out');
  });
}

// ── LOADERS ────────────────────────────────────────────────────
async function loadAll(){await Promise.all([loadStatus(),loadApps(),loadStorage(),loadAndroid()]);}
async function loadStatus(){const r=await api('/status');if(r?.ok){S.status=r;render();}}
async function loadApps(){const r=await api('/apps');if(r?.ok){S.apps=r.apps;render();}}
async function loadStorage(){
  const r=await api('/storage');
  if(r?.ok){
    S.storage=r;
    const ago=Math.floor((Date.now()-new Date(r.last_sync).getTime())/60000);
    S.lastSync=ago<1?'Just now':ago+' min ago';
    render();
  }
}
async function loadAndroid(){const r=await api('/android');if(r?.ok){S.android=r.android;render();}}

// ── PWA ────────────────────────────────────────────────────────
let dp;
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault(); dp=e; $('ib')?.classList.add('show');
});
$('ib-btn')?.addEventListener('click',async()=>{
  if(!dp)return; dp.prompt(); await dp.userChoice; dp=null; $('ib')?.classList.remove('show');
});
$('ib-x')?.addEventListener('click',()=>$('ib')?.classList.remove('show'));
if(/iphone|ipad|ipod/i.test(navigator.userAgent)&&!navigator.standalone)
  setTimeout(()=>$('ios-hint')?.classList.add('show'),5000);

if('serviceWorker'in navigator) navigator.serviceWorker.register('/sw.js').catch(()=>{});

// ── BOOT ───────────────────────────────────────────────────────
const su=LS.g('user'), st=LS.g('token');
if(su&&st){S.user=su;S.token=st;S.screen='dashboard';}
render();
if(S.screen==='dashboard') loadAll();
setInterval(()=>{if(S.screen==='dashboard') loadStatus();},30000);
</script>
</body>
</html>
